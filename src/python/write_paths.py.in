"""
Generated by CMake -- do not edit.
Writes _paths.py into the installed modena package directory.
Called by cmake --install via install(CODE ...).
"""
import os
import sysconfig

# Use posix_prefix scheme explicitly to match 'setup.py install --prefix'
# and avoid distro-specific sysconfig overrides (e.g. Debian's dist-packages).
site_packages = sysconfig.get_path(
    'purelib',
    'posix_prefix',
    vars={'platbase': '@CMAKE_INSTALL_PREFIX@', 'base': '@CMAKE_INSTALL_PREFIX@'},
)

content = (
    "# Generated by CMake -- do not edit.\n"
    "MODENA_LIB_DIR    = '@INSTALL_LIB_DIR@/modena'\n"
    "MODENA_INCLUDE_DIR = '@CMAKE_INSTALL_PREFIX@/include'\n"
    "MODENA_CMAKE_MINIMUM_VERSION = '@CMAKE_MINIMUM_REQUIRED_VERSION@'\n"
)

target = os.path.join(site_packages, 'modena', '_paths.py')
with open(target, 'w') as f:
    f.write(content)

print("-- Wrote", target)
